{
    "name": "nikoleesg/laravel-admin",
    "description": "laravel admin",
    "type": "library",
    "keywords": ["laravel", "admin", "grid", "form"],
    "homepage": "https://github.com/nikoleesg/laravel-admin",
    "license": "MIT",
    "authors": [
        {
            "name": "nikoleesg",
            "email": "nikoleesg@example.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "symfony/dom-crawler": "^7.0",
        "laravel/framework": "^11.0|^12.0",
        "doctrine/dbal": "^3.0 || ^4.0",
        "tightenco/parental": "^1.0",
        "laravolt/avatar": "^6.0",
        "spatie/eloquent-sortable": "^5.0"
    },
    "require-dev": {
        "laravel/laravel": "^11.0|^12.0",
        "fakerphp/faker": "^1.23",
        "intervention/image": "^3.11",
        "laravel/pint": "^1.13",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "laravel/browser-kit-testing": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Encore\\Admin\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Models\\": "tests/models",
            "Tests\\Controllers\\": "tests/controllers"
        },
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "scripts": {
        "test": "./vendor/bin/phpunit"
    },
    "suggest": {
        "intervention/image": "Required to handling and manipulation upload images (~2.7)."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Encore\\Admin\\AdminServiceProvider"
            ],
            "aliases": {
                "Admin": "Encore\\Admin\\Facades\\Admin"
            }
        }
    }
}
